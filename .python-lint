[MAIN]
py-version = 3.11
jobs = 0
ignore-paths = ^.*\.mdx$

[FORMAT]
max-line-length = 88
indent-string = '    '
expected-line-ending-format = LF

[DESIGN]
max-args = 7
max-branches = 15
max-locals = 20
max-returns = 6
max-statements = 60
max-attributes = 10
max-public-methods = 25
min-public-methods = 0

[MESSAGES CONTROL]
disable =
    C0114,
    C0115,
    C0116,
    C0206,
    C0301,
    C0303,
    C0411,
    C0413,
    E0401,
    E1101,
    R0801,
    R0903,
    R0917,
    R1702,
    W0511,
    W0611,
    W0612,
    W0613,
    W0621,
    W0622,
    W1514

[BASIC]
good-names = i, j, k, ex, _, id, pk, db, fn, ip, ok, df

[SIMILARITIES]
min-similarity-lines = 10
ignore-comments = yes
ignore-docstrings = yes
ignore-imports = yes
